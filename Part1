local function processCommand(message, fromGUI)
    fromGUI = fromGUI or false
    
    if not fromGUI then
        if message:sub(1, #PREFIX) ~= PREFIX then
            return
        end
        message = message:sub(#PREFIX + 1)
    end
    
    local args = message:split(" ")
    local commandName = args[1]:lower()
    
    table.remove(args, 1)
    
    if commands[commandName] then
        commands[commandName](args)
    end
end

