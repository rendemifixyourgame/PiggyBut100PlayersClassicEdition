            return
        end
        
        stunLoopActive = true
        
        task.spawn(function()
            local stunAttempts = 0
            local maxAttempts = 50
            
            while stunLoopActive and stunAttempts < maxAttempts do
                stunAttempts = stunAttempts + 1
                
                local exemptCharacters = {LocalPlayer.Character}
                
                for player, _ in pairs(permittedPlayers) do
                    if player.Character then
                        table.insert(exemptCharacters, player.Character)
                    end
                end
                
                local allStunned = true
                
                for _, model in pairs(workspace:GetDescendants()) do
                    if model:IsA("Model") and model:FindFirstChild("Head") then
                        local shouldExempt = false
                        for _, exemptChar in pairs(exemptCharacters) do
                            if model == exemptChar then
                                shouldExempt = true
                                break
                            end
                        end
                        
                        if not shouldExempt then
                            local hasStun = false
                            for _, descendant in pairs(model:GetDescendants()) do
                                if descendant:IsA("Animation") and descendant.Name == "Stun" then
                                    hasStun = true
                                    break
                                end
                            end
                            
                            if hasStun then
                                if not isModelStunned(model) then
                                    allStunned = false
                                    
                                    local stunArgs = {
                                        [1] = "Stun",
                                        [2] = "Weapon",
                                        [3] = model.Head,
                                        [4] = false,
                                        [5] = duration
                                    }
                                    ReplicatedStorage:WaitForChild("Remotes", 9e9):WaitForChild("ChapterEvent", 9e9):FireServer(unpack(stunArgs))
                                end
                            end
                        end
                    end
                end
                
                if allStunned then
                    stunLoopActive = false
                    break
                end
                
                task.wait(0.1)
            end
            
            stunLoopActive = false
        end)
    end,
    
    kill = function(args)
        if #args == 0 or args[1]:lower() ~= "traitor" then
            return
        end
        
        for _, model in pairs(workspace:GetChildren()) do
            if model:IsA("Model") and model:FindFirstChild("Torso") then
                local traitorValue = model:FindFirstChild("Traitor")
                if traitorValue and traitorValue:IsA("StringValue") then
                    local killArgs = {
                        [1] = "Stun",
                        [2] = "Weapon",
                        [3] = model.Torso,
                        [4] = false,
                        [5] = 20
                    }
                    ReplicatedStorage:WaitForChild("Remotes", 9e9):WaitForChild("ChapterEvent", 9e9):FireServer(unpack(killArgs))
                end
            end
        end
    end,
    
    equip = function(args)
        if #args < 2 then
            return
        end
        
        local objectType = args[1]:lower()
        
        if objectType ~= "trap" then
            return
        end
        
        table.remove(args, 1)
        local trapInput = table.concat(args, " "):lower()
        
        local trapName = nil
        for key, value in pairs(trapNames) do
            if trapInput:find(key) or key:find(trapInput) then
                trapName = value
                break
            end
        end
        
        if not trapName then
            return
        end
        
        local equipArgs = {
            "EquippingTrap",
            trapName
        }
        
        LocalPlayer:WaitForChild("PlayerGui"):WaitForChild("MainMenu"):WaitForChild("Shop"):WaitForChild("ShopMenu"):WaitForChild("TrapList"):WaitForChild("ShopRemote"):InvokeServer(unpack(equipArgs))
    end,
    
    perm = function(args)
        if #args < 1 then
            return
        end
        
        local targetName = args[1]:lower()
        
        local targetPlayer = nil
        for _, player in pairs(Players:GetPlayers()) do
            if player.Name:lower():find(targetName) or player.DisplayName:lower():find(targetName) then
                targetPlayer = player
                break
            end
        end
        
        if not targetPlayer then
            return
        end
        
        permittedPlayers[targetPlayer] = true
    end,
    
