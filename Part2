    TweenService:Create(titleLabel, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
    TweenService:Create(closeButton, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0, TextTransparency = 0}):Play()
    TweenService:Create(toggleLabel, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
    TweenService:Create(toggleBg, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
    TweenService:Create(toggleIndicator, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
    TweenService:Create(toggleText, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
end

-- ─────────────────────────────────────────
-- BIKE
-- ─────────────────────────────────────────
local bikeActive = false
local bikeConnections = {}
local bikeHitbox = nil
local bikeAnimTrack = nil
local bikeBodyVel = nil
local bikeMomentum = Vector3.new(0, 0, 0)
local bikeStunCooldowns = {}

local function cleanupBike()
    bikeActive = false
    for _, conn in pairs(bikeConnections) do
        pcall(function() conn:Disconnect() end)
    end
    bikeConnections = {}
    if bikeHitbox then bikeHitbox:Destroy() bikeHitbox = nil end
    if bikeBodyVel then bikeBodyVel:Destroy() bikeBodyVel = nil end
    if bikeAnimTrack then bikeAnimTrack:Stop() bikeAnimTrack = nil end
    bikeMomentum = Vector3.new(0, 0, 0)
    local char = LocalPlayer.Character
    if char then
        local animate = char:FindFirstChild("Animate")
        if animate then animate.Disabled = false end
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum.JumpPower = 50 end
    end
    print("Bike mode OFF")
end

local function startBike()
    local char = LocalPlayer.Character
    if not char then return end
    if not char:FindFirstChild("Accessory (Bike)") then
        print("You need the Bike accessory equipped!")
        return
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    bikeActive = true

    local animate = char:FindFirstChild("Animate")
    if animate then animate.Disabled = true end

    local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator")
    local sitAnim = Instance.new("Animation")
    sitAnim.AnimationId = "rbxassetid://178130996"
    bikeAnimTrack = animator:LoadAnimation(sitAnim)
    bikeAnimTrack.Looped = true
    bikeAnimTrack:Play()

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 0, 1e5)
    bv.P = 1e4
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = hrp
    bikeBodyVel = bv

    local FRICTION = 0.97
    local MOMENTUM_STRENGTH = 1.2
    local MAX_SPEED = 60

    local momentumConn = RunService.Heartbeat:Connect(function(dt)
        if not bikeActive then return end
        local c = LocalPlayer.Character
        if not c then return end
        local h = c:FindFirstChild("Humanoid")
        local r = c:FindFirstChild("HumanoidRootPart")
        if not h or not r then return end

        local moveDir = h.MoveDirection
        if moveDir.Magnitude > 0 then
            bikeMomentum = bikeMomentum + moveDir * MOMENTUM_STRENGTH
            if bikeMomentum.Magnitude > MAX_SPEED then
                bikeMomentum = bikeMomentum.Unit * MAX_SPEED
            end
        end
        -- Bleed momentum each frame
        bikeMomentum = bikeMomentum * FRICTION

        if bikeBodyVel and bikeBodyVel.Parent then
            bikeBodyVel.Velocity = bikeMomentum
        end
    end)
    table.insert(bikeConnections, momentumConn)

    -- Invisible hitbox
    local hitbox = Instance.new("Part")
    hitbox.Name = "BikeHitbox"
    hitbox.Size = Vector3.new(10, 5, 10)
    hitbox.Transparency = 1  -- fully invisible
    hitbox.CanCollide = false
    hitbox.Anchored = false
    hitbox.CFrame = hrp.CFrame
    hitbox.Parent = workspace

    local weld = Instance.new("WeldConstraint")
    weld.Part0 = hrp
    weld.Part1 = hitbox
    weld.Parent = hitbox
    bikeHitbox = hitbox

    local hitConn = RunService.Heartbeat:Connect(function()
        if not bikeActive then return end
        local c = LocalPlayer.Character
        if not c then return end
        local myHRP = c:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        local function processHit(hitChar)
            if not hitChar or hitChar == c then return end
            local hitPlayer = Players:GetPlayerFromCharacter(hitChar)
            if hitPlayer == LocalPlayer then return end

            local permitted = _G.PiggyScript and _G.PiggyScript.permittedPlayers or {}
            for _, name in pairs(permitted) do
                if name == (hitPlayer and hitPlayer.Name) then return end
            end

            local now = tick()
            local key = hitChar.Name
            if bikeStunCooldowns[key] and now - bikeStunCooldowns[key] < 2 then return end
            bikeStunCooldowns[key] = now

            local speed = bikeMomentum.Magnitude
            local stunTime = math.clamp(math.floor(speed / 5), 2, 20)

            local targetHRP = hitChar:FindFirstChild("HumanoidRootPart")
            if targetHRP and hitPlayer then
                pcall(function()
                    game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
                        :WaitForChild("ChapterEvent"):FireServer("Stun", "Weapon", targetHRP, false, stunTime)
                end)
            end

            local bounceForce = math.clamp(speed * 2.5, 25, 120)
            local bounceDir = (myHRP.Position - hitChar:GetModelCFrame().Position).Unit
            local bounceVel = Vector3.new(bounceDir.X, 0.6, bounceDir.Z).Unit * bounceForce
            bikeMomentum = Vector3.new(bounceVel.X, 0, bounceVel.Z) * 0.8

            local bounceBV = Instance.new("BodyVelocity")
            bounceBV.Velocity = bounceVel
            bounceBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bounceBV.P = 1e4
            bounceBV.Parent = myHRP
            Debris:AddItem(bounceBV, 0.25)
        end

        -- Only check NPCs (Piggy)
        for _, obj in pairs(workspace:GetChildren()) do
            if obj ~= c and obj:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
                local npcHRP = obj:FindFirstChild("HumanoidRootPart")
                if npcHRP and (npcHRP.Position - myHRP.Position).Magnitude < 6 then
                    processHit(obj)
                end
            end
        end
    end)
    table.insert(bikeConnections, hitConn)

    print("Bike mode ON")
end

-- ─────────────────────────────────────────
-- !RE COMMAND
-- Saves position → morphs to George (false)
-- → waits for character to reload → TPs back
-- ─────────────────────────────────────────
local function doRe()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Save position before morph
    local savedCFrame = hrp.CFrame

    -- Fire morph
    game.ReplicatedStorage:WaitForChild("MoreRemotes").MorphIntoCharacter:FireServer("George", false)

    -- Wait for character to respawn/reload then TP back
    task.spawn(function()
        -- Wait for old character to go away
        local oldChar = LocalPlayer.Character
        local timeout = tick() + 5
        while LocalPlayer.Character == oldChar and tick() < timeout do
            task.wait(0.1)
        end
        -- Wait for new character's HRP to exist
        local newChar = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local newHRP = newChar:FindFirstChild("HumanoidRootPart")
        if not newHRP then
            newHRP = newChar:WaitForChild("HumanoidRootPart", 5)
        end
        if newHRP then
            task.wait(0.2) -- small settle delay
            newHRP.CFrame = savedCFrame
        end
    end)
end

