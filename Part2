if game.PlaceId ~= 133500464897785 then return end

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local function getPermitted()
    return (_G.PiggyScript and _G.PiggyScript.permittedPlayers) or {}
end

local PREFIX = (_G.PiggyScript and _G.PiggyScript.PREFIX) or "!"

local function isPiggy(player)
    player = player or LocalPlayer
    local char = player.Character
    return char ~= nil and char:FindFirstChild("Traitor") ~= nil
end

local highlights = {}
local firstTap = { player = nil, time = 0 }
local DOUBLE_TAP_TIME = 0.5

local function isHighlightTarget(player)
    local permitted = getPermitted()
    return player ~= LocalPlayer and not permitted[player] and not isPiggy(player)
end

local function clearHighlights()
    for _, h in pairs(highlights) do
        if h and h.Parent then h:Destroy() end
    end
    highlights = {}
    firstTap = { player = nil, time = 0 }
end

local function setHighlightColor(player, color)
    local h = highlights[player]
    if h then
        h.FillColor = color
        h.OutlineColor = color
    end
end

local function updateHighlights()
    for _, player in pairs(Players:GetPlayers()) do
        if isHighlightTarget(player) then
            local char = player.Character
            if char and not highlights[player] then
                local h = Instance.new("Highlight")
                h.FillColor = Color3.fromRGB(255, 255, 255)
                h.OutlineColor = Color3.fromRGB(255, 255, 255)
                h.FillTransparency = 0.5
                h.OutlineTransparency = 0
                h.Adornee = char
                h.Parent = char
                highlights[player] = h
            elseif not char and highlights[player] then
                if highlights[player].Parent then highlights[player]:Destroy() end
                highlights[player] = nil
            end
        end
    end

    for player, h in pairs(highlights) do
        if not player.Parent or not isHighlightTarget(player) then
            if h and h.Parent then h:Destroy() end
            highlights[player] = nil
        end
    end
end

local function getPlayerFromHit(hit)
    if not hit then return nil end
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character and hit:IsDescendantOf(player.Character) then
            return player
        end
    end
    return nil
end

local mouse = LocalPlayer:GetMouse()

local function handleTap()
    if not isPiggy() then return end

    local targetPlayer = getPlayerFromHit(mouse.Target)

    if not targetPlayer or not highlights[targetPlayer] then
        if firstTap.player then
            setHighlightColor(firstTap.player, Color3.fromRGB(255, 255, 255))
            firstTap = { player = nil, time = 0 }
        end
        return
    end

    local now = tick()

    if firstTap.player == targetPlayer and (now - firstTap.time) <= DOUBLE_TAP_TIME then
        setHighlightColor(targetPlayer, Color3.fromRGB(255, 240, 100))

        local myChar = LocalPlayer.Character
        local targetChar = targetPlayer.Character
        if myChar and targetChar then
            local myRoot = myChar:FindFirstChild("HumanoidRootPart")
            local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
            if myRoot and targetRoot then
                myRoot.CFrame = targetRoot.CFrame
            end
        end

        task.delay(0.3, function()
            setHighlightColor(targetPlayer, Color3.fromRGB(255, 255, 255))
        end)

        firstTap = { player = nil, time = 0 }
    else
        if firstTap.player and firstTap.player ~= targetPlayer then
            setHighlightColor(firstTap.player, Color3.fromRGB(255, 255, 255))
        end
        firstTap = { player = targetPlayer, time = now }
        setHighlightColor(targetPlayer, Color3.fromRGB(255, 240, 100))
    end
end

mouse.Button1Down:Connect(handleTap)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        handleTap()
    end
end)

local wasPiggy = false
RunService.Heartbeat:Connect(function()
    local nowPiggy = isPiggy()

    if nowPiggy ~= wasPiggy then
        if not nowPiggy then
            clearHighlights()
        end
        wasPiggy = nowPiggy
    end

    if nowPiggy then
        updateHighlights()
    end
end)

local activeForcefields = {}

local function removeForcefield(player)
    if activeForcefields[player] then
        local ff = activeForcefields[player]
        if ff and ff.Parent then ff:Destroy() end
        activeForcefields[player] = nil
    end
end

local function createForcefield(targetPlayer, size, stunDuration)
    removeForcefield(targetPlayer)

    local char = targetPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local part = Instance.new("Part")
    part.Name = "Forcefield_" .. targetPlayer.Name
    part.Size = Vector3.new(size, size, size)
    part.Shape = Enum.PartType.Ball
    part.Material = Enum.Material.ForceField
    part.Color = Color3.fromRGB(100, 200, 255)
    part.Transparency = 0.3
    part.CanCollide = false
    part.Anchored = false
    part.CastShadow = false
    part.CFrame = root.CFrame
    part.Parent = workspace

    local weld = Instance.new("WeldConstraint")
    weld.Part0 = root
    weld.Part1 = part
    weld.Parent = part

    activeForcefields[targetPlayer] = part

    local debounce = {}
    part.Touched:Connect(function(hit)
        local touchModel = hit.Parent
        if not touchModel then return end

        local touchPlayer = Players:GetPlayerFromCharacter(touchModel)
        local permitted = getPermitted()

        if touchPlayer then
            if touchPlayer == LocalPlayer then return end
            if permitted[touchPlayer] then return end
            if touchPlayer == targetPlayer then return end
        end

        if not touchModel:FindFirstChild("Head") then return end
        if debounce[touchModel] then return end
        debounce[touchModel] = true

        local stunArgs = {
            [1] = "Stun",
            [2] = "Weapon",
            [3] = touchModel.Head,
            [4] = false,
            [5] = stunDuration
        }
        ReplicatedStorage:WaitForChild("Remotes", 9e9):WaitForChild("ChapterEvent", 9e9):FireServer(unpack(stunArgs))

        task.delay(1, function()
            debounce[touchModel] = nil
        end)
    end)

    char.AncestryChanged:Connect(function()
        removeForcefield(targetPlayer)
    end)
end

local function parseForcefieldArgs(args, caller)
    caller = caller or LocalPlayer

    if #args == 0 then
        return {caller}, 10, 5
    end

    local targets = {}
    local size = 10
    local stunValue = 5
    local idx = 1
    local first = args[1]:lower()

    if first == "me" or first == caller.Name:lower() or first == caller.DisplayName:lower() then
        table.insert(targets, caller)
        idx = 2
    elseif first == "all" then
        for _, p in pairs(Players:GetPlayers()) do
            if not isPiggy(p) then
                table.insert(targets, p)
            end
        end
        idx = 2
    else
        local found = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(first, 1, true) or p.DisplayName:lower():find(first, 1, true) then
                found = p
                break
            end
        end

        if found then
            table.insert(targets, found)
            idx = 2
        else
            table.insert(targets, caller)
            idx = 1
        end
    end

    size = tonumber(args[idx]) or 10
    stunValue = tonumber(args[idx + 1]) or 5

    return targets, size, stunValue
end

local function handleForcefield(args, caller)
    caller = caller or LocalPlayer

    if isPiggy(caller) then return end

    local targets, size, stunValue = parseForcefieldArgs(args, caller)
    if not targets then return end

    for _, target in ipairs(targets) do
        createForcefield(target, size, stunValue)
    end
end

if _G.PiggyScript and _G.PiggyScript.commands then
    _G.PiggyScript.commands.forcefield = function(args)
        handleForcefield(args, LocalPlayer)
    end
end

LocalPlayer.Chatted:Connect(function(msg)
    if msg:sub(1, #PREFIX) ~= PREFIX then return end
    local body = msg:sub(#PREFIX + 1)
    local parts = body:split(" ")
    local cmd = parts[1]:lower()
    table.remove(parts, 1)

    if cmd == "forcefield" then
        handleForcefield(parts, LocalPlayer)
    end
end)

Players.PlayerAdded:Connect(function(player)
    player.Chatted:Connect(function(msg)
        if msg:sub(1, #PREFIX) ~= PREFIX then return end
        local permitted = getPermitted()
        if not permitted[player] then return end

        local body = msg:sub(#PREFIX + 1)
        local parts = body:split(" ")
        local cmd = parts[1]:lower()
        table.remove(parts, 1)

        if cmd == "forcefield" then
            handleForcefield(parts, player)
        end
    end)
end)

for _, player in pairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.Chatted:Connect(function(msg)
            if msg:sub(1, #PREFIX) ~= PREFIX then return end
            local permitted = getPermitted()
            if not permitted[player] then return end

            local body = msg:sub(#PREFIX + 1)
            local parts = body:split(" ")
            local cmd = parts[1]:lower()
            table.remove(parts, 1)

            if cmd == "forcefield" then
                handleForcefield(parts, player)
            end
        end)
    end
end
