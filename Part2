if _G.PiggyScript and _G.PiggyScript.commands then
    _G.PiggyScript.commands.autoclick = function()
        createAutoclickGUI()
    end
    _G.PiggyScript.commands.george = function()
        game.ReplicatedStorage:WaitForChild("MoreRemotes").MorphIntoCharacter:FireServer("George", true)
    end
    _G.PiggyScript.commands.bike = function()
        if bikeActive then cleanupBike() else startBike() end
    end
    _G.PiggyScript.commands.re = function()
        doRe()
    end
end

local PREFIX = (_G.PiggyScript and _G.PiggyScript.PREFIX) or "!"

LocalPlayer.Chatted:Connect(function(msg)
    if msg:sub(1, #PREFIX) ~= PREFIX then return end
    local body = msg:sub(#PREFIX + 1)
    local parts = body:split(" ")
    local cmd = parts[1]:lower()

    if cmd == "autoclick" then
        createAutoclickGUI()
    elseif cmd == "george" then
        game.ReplicatedStorage:WaitForChild("MoreRemotes").MorphIntoCharacter:FireServer("George", true)
    elseif cmd == "bike" then
        if bikeActive then cleanupBike() else startBike() end
    elseif cmd == "re" then
        doRe()
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    if bikeActive then cleanupBike() end
end)
