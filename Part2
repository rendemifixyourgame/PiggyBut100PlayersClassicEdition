    local function startAutoclick()
        autoclickId = autoclickId + 1
        local myId = autoclickId
        task.spawn(function()
            while autoclicking and autoclickId == myId do
                for _, desc in pairs(workspace.Map:GetDescendants()) do
                    if desc:IsA("ClickDetector") then
                        fireclickdetector(desc)
                    end
                end
                task.wait(0.05)
            end
        end)
    end

