    TweenService:Create(toggleIndicator, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
    TweenService:Create(toggleText, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
end

if _G.PiggyScript and _G.PiggyScript.commands then
    _G.PiggyScript.commands.autoclick = function(args)
        createAutoclickGUI()
    end
end

local PREFIX = (_G.PiggyScript and _G.PiggyScript.PREFIX) or "!"

LocalPlayer.Chatted:Connect(function(msg)
    if msg:sub(1, #PREFIX) ~= PREFIX then return end
    local body = msg:sub(#PREFIX + 1)
    local parts = body:split(" ")
    local cmd = parts[1]:lower()
    table.remove(parts, 1)

    if cmd == "autoclick" then
        createAutoclickGUI()
    end
end)
