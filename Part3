local function equipTrap(trapName)
    local args = { "EquippingTrap", trapName }
    game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
        :WaitForChild("MainMenu"):WaitForChild("Shop")
        :WaitForChild("ShopMenu"):WaitForChild("TrapList")
        :WaitForChild("ShopRemote"):InvokeServer(unpack(args))
end

local function placeTrap()
    local args = { "PlaceTrap" }
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
        :WaitForChild("ChapterEvent"):FireServer(unpack(args))
end

local function getRaycastPosition()
    local unitRay = Camera:ScreenPointToRay(
        Camera.ViewportSize.X / 2,
        Camera.ViewportSize.Y / 2
    )
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = { LocalPlayer.Character, previewPart }
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, raycastParams)
    if result then
        return result.Position
    end
    return nil
end

local function createPreviewPart()
    if previewPart then previewPart:Destroy() end
    local part = Instance.new("Part")
    part.Size = Vector3.new(CANVAS_SIZE, 0.1, CANVAS_SIZE)
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 0.5
    part.BrickColor = BrickColor.new("Bright blue")
    part.Material = Enum.Material.Neon
    part.Parent = workspace
    previewPart = part

    -- Grid lines texture
    local texture = Instance.new("Texture")
    texture.Texture = "rbxassetid://6372755229"
    texture.StudsPerTileU = GRID_SIZE
    texture.StudsPerTileV = GRID_SIZE
    texture.Transparency = 0.5
    texture.Face = Enum.NormalId.Top
    texture.Parent = part

    return part
end

local function updatePreviewPosition()
    if not previewPart then return end
    local pos = getRaycastPosition()
    if pos then
        previewPart.CFrame = CFrame.new(pos.X, pos.Y + 0.05, pos.Z) 
            * CFrame.Angles(0, math.rad(currentRotation), 0)
    end
end

local function destroyPreview()
    if previewPart then
        previewPart:Destroy()
        previewPart = nil
    end
end

local function destroyGUI()
    if drawGUI then
        drawGUI:Destroy()
        drawGUI = nil
    end
end

local function startPlacement()
    if not pixelData or not previewPart then return end

    local origin = previewPart.CFrame
    destroyPreview()
    placementActive = true

    -- Separate white and black pixels
    local whitePixels = {}
    local blackPixels = {}
    for _, pixel in pairs(pixelData) do
        if pixel.color == "white" then
            table.insert(whitePixels, pixel)
        else
            table.insert(blackPixels, pixel)
        end
    end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local function getWorldPos(pixel)
        local offsetX = (pixel.x - 32) * GRID_SIZE
        local offsetZ = (pixel.y - 32) * GRID_SIZE
        local localOffset = Vector3.new(offsetX, 0, offsetZ)
        local worldOffset = origin:VectorToWorldSpace(localOffset)
        return origin.Position + worldOffset
    end

    -- Place white pixels first
    equipTrap("Default")
    task.wait(0.2)
    for _, pixel in pairs(whitePixels) do
        if not placementActive then break end
        local pos = getWorldPos(pixel)
        hrp.CFrame = CFrame.new(pos.X, hrp.Position.Y, pos.Z)
        task.wait()
        placeTrap()
        task.wait()
    end

    -- Place black pixels
    equipTrap("Black Hole")
    task.wait(0.2)
    for _, pixel in pairs(blackPixels) do
        if not placementActive then break end
        local pos = getWorldPos(pixel)
        hrp.CFrame = CFrame.new(pos.X, hrp.Position.Y, pos.Z)
        task.wait()
        placeTrap()
        task.wait()
    end

    placementActive = false
    print("Draw complete!")
end

