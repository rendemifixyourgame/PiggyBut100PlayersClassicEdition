if game.PlaceId ~= 133500464897785 then return end

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local API_URL = "https://drawstuff-api-production.up.railway.app/convert?url="
local GRID_SIZE = 3
local CANVAS_SIZE = 64 * GRID_SIZE
local HOVER_HEIGHT = 10

local drawGUI = nil
local previewPart = nil
local pixelData = nil
local placementActive = false
local currentRotation = 0

local PREFIX = (_G.PiggyScript and _G.PiggyScript.PREFIX) or "!"

local function equipTrap(trapName)
    local current = nil
    local trapGui = LocalPlayer:FindFirstChild("PlayerGui")
    if trapGui then
        local gameGUI = trapGui:FindFirstChild("GameGUI")
        if gameGUI then
            local trap = gameGUI:FindFirstChild("Trap")
            if trap then
                local trapsVal = trap:FindFirstChild("Traps_")
                current = trapsVal and trapsVal.Value or nil
            end
        end
    end
    if current == trapName then return end
    LocalPlayer:WaitForChild("PlayerGui")
        :WaitForChild("MainMenu"):WaitForChild("Shop")
        :WaitForChild("ShopMenu"):WaitForChild("TrapList")
        :WaitForChild("ShopRemote"):InvokeServer("EquippingTrap", trapName)
    task.wait(0.3)
end

local function placeTrap()
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
        :WaitForChild("ChapterEvent"):FireServer("PlaceTrap")
end

local function disableMovement(hrp)
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = 0
        hum.JumpPower = 0
        hum.AutoRotate = false
    end
    -- Anchor HRP so character doesn't fall
    if hrp then hrp.Anchored = true end
end

local function enableMovement(hrp)
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = 16
        hum.JumpPower = 50
        hum.AutoRotate = true
    end
    if hrp then hrp.Anchored = false end
end

local function destroyPreview()
    if previewPart then previewPart:Destroy() previewPart = nil end
end

local function destroyGUI()
    if drawGUI then drawGUI:Destroy() drawGUI = nil end
end

local function createPreviewPart(imageUrl)
    if previewPart then previewPart:Destroy() end
    local part = Instance.new("Part")
    part.Size = Vector3.new(CANVAS_SIZE, 0.1, CANVAS_SIZE)
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 0
    part.BrickColor = BrickColor.new("White")
    part.Material = Enum.Material.SmoothPlastic
    part.Parent = workspace
    previewPart = part
    local decal = Instance.new("Decal")
    decal.Texture = imageUrl
    decal.Face = Enum.NormalId.Top
    decal.Parent = part
    return part
end

local function startPlacement()
    if not pixelData or not previewPart then return end

    local origin = previewPart.CFrame
    destroyPreview()
    placementActive = true

    local whitePixels = {}
    local blackPixels = {}
    for _, pixel in pairs(pixelData) do
        if pixel.color == "white" then
            table.insert(whitePixels, pixel)
        else
            table.insert(blackPixels, pixel)
        end
    end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then placementActive = false return end

    disableMovement(hrp)

    -- Snap to start position floating above canvas, lying flat
    hrp.CFrame = CFrame.new(origin.Position.X, origin.Position.Y + HOVER_HEIGHT, origin.Position.Z)
        * CFrame.Angles(math.rad(90), 0, 0)
    task.wait(0.2)

    local function getWorldPos(pixel)
        local offsetX = (pixel.x - 32) * GRID_SIZE
        local offsetZ = (pixel.y - 32) * GRID_SIZE
        local worldOffset = origin:VectorToWorldSpace(Vector3.new(offsetX, 0, offsetZ))
        return Vector3.new(
            origin.Position.X + worldOffset.X,
            origin.Position.Y + HOVER_HEIGHT,
            origin.Position.Z + worldOffset.Z
        )
    end

    local function placeAtPos(pos)
        if not placementActive then return end
        local tween = TweenService:Create(hrp, TweenInfo.new(0.08, Enum.EasingStyle.Linear), {
            CFrame = CFrame.new(pos) * CFrame.Angles(math.rad(90), 0, 0)
        })
        tween:Play()
        tween.Completed:Wait()
        placeTrap()
    end

    print("Equipping Default trap...")
    equipTrap("Default")
    print("Placing white pixels...")
    for _, pixel in pairs(whitePixels) do
        if not placementActive then break end
        placeAtPos(getWorldPos(pixel))
    end

    print("Equipping Black Hole trap...")
    equipTrap("Black Hole")
    print("Placing black pixels...")
    for _, pixel in pairs(blackPixels) do
        if not placementActive then break end
        placeAtPos(getWorldPos(pixel))
    end

    enableMovement(hrp)
    placementActive = false
    print("Draw complete!")
end

