-- Get currently equipped trap
local function getCurrentTrap()
    local trapGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not trapGui then return nil end
    local gameGUI = trapGui:FindFirstChild("GameGUI")
    if not gameGUI then return nil end
    local trap = gameGUI:FindFirstChild("Trap")
    if not trap then return nil end
    local trapsVal = trap:FindFirstChild("Traps_")
    return trapsVal and trapsVal.Value or nil
end

local function equipTrap(trapName)
    if getCurrentTrap() == trapName then return end
    LocalPlayer:WaitForChild("PlayerGui")
        :WaitForChild("MainMenu"):WaitForChild("Shop")
        :WaitForChild("ShopMenu"):WaitForChild("TrapList")
        :WaitForChild("ShopRemote"):InvokeServer("EquippingTrap", trapName)
    task.wait(0.3)
end

local function placeTrap()
    ReplicatedStorage:WaitForChild("Remotes")
        :WaitForChild("ChapterEvent"):FireServer("PlaceTrap")
end

local function trapExistsNear(pos, radius)
    radius = radius or GRID_SIZE
    local mapOk, descendants = pcall(function()
        return workspace.Map:GetDescendants()
    end)
    if not mapOk then return false end
    for _, obj in pairs(descendants) do
        if obj:IsA("BasePart") and (obj.Name == "Default" or obj.Name == "Black Hole") then
            if (obj.Position - pos).Magnitude <= radius then
                return true
            end
        end
    end
    return false
end

local function createPlatform(originCFrame)
    if platform then platform:Destroy() end
    local p = Instance.new("Part")
    p.Size = Vector3.new(CANVAS_SIZE, 1, CANVAS_SIZE)
    p.CFrame = CFrame.new(originCFrame.Position.X, originCFrame.Position.Y - 0.5, originCFrame.Position.Z)
        * CFrame.Angles(0, math.rad(currentRotation), 0)
    p.Anchored = true
    p.CanCollide = true
    p.Transparency = 1
    p.Parent = workspace
    platform = p
end

local function destroyPlatform()
    if platform then
        platform:Destroy()
        platform = nil
    end
end

local function disableMovement()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = 0
        hum.JumpPower = 0
    end
end

local function enableMovement()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = 16
        hum.JumpPower = 50
    end
end

local function destroyPreview()
    if previewPart then
        previewPart:Destroy()
        previewPart = nil
    end
end

local function destroyGUI()
    if drawGUI then
        drawGUI:Destroy()
        drawGUI = nil
    end
end

local function createPreviewPart(imageUrl)
    destroyPreview()
    local part = Instance.new("Part")
    part.Size = Vector3.new(CANVAS_SIZE, 0.1, CANVAS_SIZE)
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 0
    part.BrickColor = BrickColor.new("White")
    part.Material = Enum.Material.SmoothPlastic
    part.Parent = workspace
    previewPart = part

    local decal = Instance.new("Decal")
    decal.Texture = imageUrl
    decal.Face = Enum.NormalId.Top
    decal.Parent = part

    return part
end

local function startPlacement()
    if not pixelData or not previewPart then return end

    local origin = previewPart.CFrame
    destroyPreview()
    placementActive = true

    local whitePixels = {}
    local blackPixels = {}
    for _, pixel in pairs(pixelData) do
        if pixel.color == "white" then
            table.insert(whitePixels, pixel)
        else
            table.insert(blackPixels, pixel)
        end
    end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        placementActive = false
        return
    end

    -- Spawn platform at canvas origin so character stands on it
    createPlatform(origin)

    -- Teleport character onto platform center
    hrp.CFrame = CFrame.new(origin.Position.X, origin.Position.Y + 3, origin.Position.Z)
    task.wait(0.5)

    disableMovement()

    local function getWorldPos(pixel)
        local offsetX = (pixel.x - 32) * GRID_SIZE
        local offsetZ = (pixel.y - 32) * GRID_SIZE
        local localOffset = Vector3.new(offsetX, 0, offsetZ)
        local worldOffset = origin:VectorToWorldSpace(localOffset)
        return Vector3.new(
            origin.Position.X + worldOffset.X,
            origin.Position.Y + 3,
            origin.Position.Z + worldOffset.Z
        )
    end

    local function placeWithRetry(pos, maxRetries)
        maxRetries = maxRetries or 3
        local floorPos = Vector3.new(pos.X, origin.Position.Y, pos.Z)
        for attempt = 1, maxRetries do
            hrp.CFrame = CFrame.new(pos)
            task.wait(0.05)
            placeTrap()
            task.wait(0.15)
            if trapExistsNear(floorPos) then
                return true
            end
        end
        return false
    end

    -- White (Default) traps first
    print("Placing Default traps (" .. #whitePixels .. " pixels)...")
    equipTrap("Default")
    local whitePlaced = 0
    for _, pixel in pairs(whitePixels) do
        if not placementActive then break end
        local pos = getWorldPos(pixel)
        if placeWithRetry(pos) then
            whitePlaced += 1
        end
    end
    print("Default traps placed: " .. whitePlaced .. "/" .. #whitePixels)

    -- Black (Black Hole) traps second
    print("Placing Black Hole traps (" .. #blackPixels .. " pixels)...")
    equipTrap("Black Hole")
    local blackPlaced = 0
    for _, pixel in pairs(blackPixels) do
        if not placementActive then break end
        local pos = getWorldPos(pixel)
        if placeWithRetry(pos) then
            blackPlaced += 1
        end
    end
    print("Black Hole traps placed: " .. blackPlaced .. "/" .. #blackPixels)

    enableMovement()
    destroyPlatform()
    placementActive = false
    print("Draw complete! (" .. (whitePlaced + blackPlaced) .. "/" .. (#whitePixels + #blackPixels) .. " total traps placed)")
end

local function spawnControlGUI(playerGui)
    local controlGui = Instance.new("ScreenGui")
    controlGui.Name = "DrawControlGUI"
    controlGui.ResetOnSpawn = false
    controlGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    controlGui.Parent = playerGui
    drawGUI = controlGui

    local controlFrame = Instance.new("Frame")
    controlFrame.Size = UDim2.new(0, 290, 0, 100)
    controlFrame.Position = UDim2.new(0.5, -145, 1, -120)
    controlFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    controlFrame.BorderSizePixel = 0
    controlFrame.BackgroundTransparency = 1
    controlFrame.Parent = controlGui

    local controlCorner = Instance.new("UICorner")
    controlCorner.CornerRadius = UDim.new(0, 12)
    controlCorner.Parent = controlFrame

    local function makeBtn(text, bgColor, xPos, yPos, w, h)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, w, 0, h)
        btn.Position = UDim2.new(0, xPos, 0, yPos)
        btn.BackgroundColor3 = bgColor
        btn.BorderSizePixel = 0
        btn.Text = text
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 14
        btn.Font = Enum.Font.GothamBold
        btn.BackgroundTransparency = 1
        btn.TextTransparency = 1
        btn.Parent = controlFrame
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, 8)
        c.Parent = btn
        return btn
    end

    local rotateLeftBtn  = makeBtn("◄ Left",  Color3.fromRGB(60, 60, 180),  10, 15, 80, 40)
    local rotateRightBtn = makeBtn("Right ►", Color3.fromRGB(60, 60, 180), 100, 15, 80, 40)
    local placeBtn       = makeBtn("Place!",  Color3.fromRGB(50, 180, 50), 200, 15, 80, 40)
    local cancelBtn      = makeBtn("Cancel",  Color3.fromRGB(200, 50, 50),  10, 60, 270, 30)

    local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    TweenService:Create(controlFrame,    tweenInfo, {BackgroundTransparency = 0}):Play()
    for _, btn in pairs({rotateLeftBtn, rotateRightBtn, placeBtn, cancelBtn}) do
        TweenService:Create(btn, tweenInfo, {BackgroundTransparency = 0, TextTransparency = 0}):Play()
    end

    rotateLeftBtn.MouseButton1Click:Connect(function()
        currentRotation = currentRotation - 90
        if previewPart then
            previewPart.CFrame = CFrame.new(previewPart.Position)
                * CFrame.Angles(0, math.rad(currentRotation), 0)
        end
    end)

    rotateRightBtn.MouseButton1Click:Connect(function()
        currentRotation = currentRotation + 90
        if previewPart then
            previewPart.CFrame = CFrame.new(previewPart.Position)
                * CFrame.Angles(0, math.rad(currentRotation), 0)
        end
    end)

    placeBtn.MouseButton1Click:Connect(function()
        destroyGUI()
        task.spawn(startPlacement)
    end)

    cancelBtn.MouseButton1Click:Connect(function()
        destroyGUI()
        destroyPreview()
        pixelData = nil
        placementActive = false
        currentRotation = 0
    end)
end

