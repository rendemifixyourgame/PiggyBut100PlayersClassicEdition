            controlFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
            controlFrame.BorderSizePixel = 0
            controlFrame.BackgroundTransparency = 1
            controlFrame.Parent = controlGui
            Instance.new("UICorner", controlFrame).CornerRadius = UDim.new(0, 12)

            local function makeBtn(text, color, x, y, w, h)
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(0, w, 0, h)
                btn.Position = UDim2.new(0, x, 0, y)
                btn.BackgroundColor3 = color
                btn.BorderSizePixel = 0
                btn.Text = text
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btn.TextSize = 14
                btn.Font = Enum.Font.GothamBold
                btn.BackgroundTransparency = 1
                btn.TextTransparency = 1
                btn.Parent = controlFrame
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
                TweenService:Create(btn, tweenInfo, {BackgroundTransparency = 0, TextTransparency = 0}):Play()
                return btn
            end

            TweenService:Create(controlFrame, tweenInfo, {BackgroundTransparency = 0}):Play()

            local rotateLeftBtn  = makeBtn("◄ Left",  Color3.fromRGB(60, 60, 180),  10, 15, 80, 40)
            local rotateRightBtn = makeBtn("Right ►", Color3.fromRGB(60, 60, 180), 100, 15, 80, 40)
            local placeBtn       = makeBtn("Place!",  Color3.fromRGB(50, 180, 50), 200, 15, 80, 40)
            local cancelBtn      = makeBtn("Cancel",  Color3.fromRGB(200, 50, 50),  10, 60, 270, 30)

            rotateLeftBtn.MouseButton1Click:Connect(function()
                currentRotation = currentRotation - 90
                if previewPart then
                    previewPart.CFrame = CFrame.new(previewPart.Position) * CFrame.Angles(0, math.rad(currentRotation), 0)
                end
            end)
            rotateRightBtn.MouseButton1Click:Connect(function()
                currentRotation = currentRotation + 90
                if previewPart then
                    previewPart.CFrame = CFrame.new(previewPart.Position) * CFrame.Angles(0, math.rad(currentRotation), 0)
                end
            end)
            placeBtn.MouseButton1Click:Connect(function()
                destroyGUI()
                task.spawn(startPlacement)
            end)
            cancelBtn.MouseButton1Click:Connect(function()
                destroyGUI() destroyPreview()
                pixelData = nil placementActive = false currentRotation = 0
            end)
        end)
    end)
end

UserInputService.InputChanged:Connect(function(input)
    if not previewPart then return end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
    if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) and input.UserInputType ~= Enum.UserInputType.Touch then return end
    local unitRay = Camera:ScreenPointToRay(input.Position.X, input.Position.Y)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = { LocalPlayer.Character, previewPart }
    params.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, params)
    if result then
        previewPart.CFrame = CFrame.new(result.Position.X, result.Position.Y + 0.05, result.Position.Z)
            * CFrame.Angles(0, math.rad(currentRotation), 0)
    end
end)

