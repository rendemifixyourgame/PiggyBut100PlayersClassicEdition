local Camera = workspace.CurrentCamera

local API_URL = "https://drawstuff-api-production.up.railway.app/convert?url="
local GRID_SIZE = 3
local CANVAS_SIZE = 64 * GRID_SIZE

local drawGUI = nil
local previewParts = {}
local pixelData = nil
local placementActive = false
local currentRotation = 0
local platform = nil

local PREFIX = (_G.PiggyScript and _G.PiggyScript.PREFIX) or "!"

local function getCurrentTrap()
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return nil end
    local gg = pg:FindFirstChild("GameGUI")
    if not gg then return nil end
    local t = gg:FindFirstChild("Trap")
    if not t then return nil end
    local v = t:FindFirstChild("Traps_")
    return v and v.Value or nil
end

local function equipTrap(trapName)
    if getCurrentTrap() == trapName then return end
    LocalPlayer:WaitForChild("PlayerGui")
        :WaitForChild("MainMenu"):WaitForChild("Shop")
        :WaitForChild("ShopMenu"):WaitForChild("TrapList")
        :WaitForChild("ShopRemote"):InvokeServer("EquippingTrap", trapName)
    task.wait(0.2)
end

local function placeTrap()
    ReplicatedStorage:WaitForChild("Remotes")
        :WaitForChild("ChapterEvent"):FireServer("PlaceTrap")
end

local function trapExistsNear(pos, radius)
    radius = radius or GRID_SIZE
    local ok, desc = pcall(function() return workspace.Map:GetDescendants() end)
    if not ok then return false end
    for _, obj in pairs(desc) do
        if obj:IsA("BasePart") and (obj.Name == "Default" or obj.Name == "Black Hole") then
            if (obj.Position - pos).Magnitude <= radius then return true end
        end
    end
    return false
end

local function createPlatform(originCFrame)
    if platform then platform:Destroy() end
    local p = Instance.new("Part")
    p.Size = Vector3.new(CANVAS_SIZE, 1, CANVAS_SIZE)
    p.CFrame = CFrame.new(originCFrame.Position.X, originCFrame.Position.Y - 0.5, originCFrame.Position.Z)
        * CFrame.Angles(0, math.rad(currentRotation), 0)
    p.Anchored = true
    p.CanCollide = true
    p.Transparency = 1
    p.Parent = workspace
    platform = p
end

local function destroyPlatform()
    if platform then platform:Destroy() platform = nil end
end

local function disableMovement()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = 0 hum.JumpPower = 0 end
end

local function enableMovement()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = 16 hum.JumpPower = 50 end
end

local function destroyPreview()
    for _, p in pairs(previewParts) do
        pcall(function() p:Destroy() end)
    end
    previewParts = {}
end

local function destroyGUI()
    if drawGUI then drawGUI:Destroy() drawGUI = nil end
end

local previewOriginCFrame = nil

local function buildPreview(pixels, originCFrame)
    destroyPreview()
    previewOriginCFrame = originCFrame

    for _, pixel in pairs(pixels) do
        local offsetX = (pixel.x - 32) * GRID_SIZE
        local offsetZ = (pixel.y - 32) * GRID_SIZE

        local part = Instance.new("Part")
        part.Shape = Enum.PartType.Cylinder
        part.Size = Vector3.new(0.2, GRID_SIZE, GRID_SIZE)
        part.Anchored = true
        part.CanCollide = false
        part.CastShadow = false
        part.BrickColor = pixel.color == "black"
            and BrickColor.new("Really black")
            or BrickColor.new("White")
        part.Material = Enum.Material.SmoothPlastic

        local worldPos = originCFrame:PointToWorldSpace(Vector3.new(offsetX, 0, offsetZ))
        part.CFrame = CFrame.new(worldPos) * CFrame.Angles(0, 0, math.rad(90))
        part.Parent = workspace
        table.insert(previewParts, part)
    end
end

local function movePreview(newOriginCFrame)
    previewOriginCFrame = newOriginCFrame
    local idx = 1
    for _, pixel in pairs(pixelData) do
        local part = previewParts[idx]
        if part then
            local offsetX = (pixel.x - 32) * GRID_SIZE
            local offsetZ = (pixel.y - 32) * GRID_SIZE
            local worldPos = newOriginCFrame:PointToWorldSpace(Vector3.new(offsetX, 0, offsetZ))
            part.CFrame = CFrame.new(worldPos) * CFrame.Angles(0, 0, math.rad(90))
        end
        idx += 1
    end
end

local function startPlacement()
    if not pixelData or #previewParts == 0 then return end

    local origin = previewOriginCFrame
    destroyPreview()
    placementActive = true

    local whitePixels = {}
    local blackPixels = {}
    for _, pixel in pairs(pixelData) do
        if pixel.color == "white" then
            table.insert(whitePixels, pixel)
        else
            table.insert(blackPixels, pixel)
        end
    end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then placementActive = false return end

    createPlatform(origin)
    hrp.CFrame = CFrame.new(origin.Position.X, origin.Position.Y + 3, origin.Position.Z)
    task.wait(0.3)
    disableMovement()

    local function getWorldPos(pixel)
        local offsetX = (pixel.x - 32) * GRID_SIZE
        local offsetZ = (pixel.y - 32) * GRID_SIZE
        local worldOffset = origin:VectorToWorldSpace(Vector3.new(offsetX, 0, offsetZ))
        return Vector3.new(
            origin.Position.X + worldOffset.X,
            origin.Position.Y + 3,
            origin.Position.Z + worldOffset.Z
        )
    end

    local function placeWithRetry(pos, maxRetries)
        local floorPos = Vector3.new(pos.X, origin.Position.Y, pos.Z)
        for _ = 1, (maxRetries or 3) do
            hrp.CFrame = CFrame.new(pos)
            task.wait()
            placeTrap()
            task.wait()
            if trapExistsNear(floorPos) then return true end
        end
        return false
    end

    print("Placing Default traps (" .. #whitePixels .. ")...")
    equipTrap("Default")
    local whitePlaced = 0
    for _, pixel in pairs(whitePixels) do
        if not placementActive then break end
        if placeWithRetry(getWorldPos(pixel)) then whitePlaced += 1 end
    end
    print("Default: " .. whitePlaced .. "/" .. #whitePixels)

    print("Placing Black Hole traps (" .. #blackPixels .. ")...")
    equipTrap("Black Hole")
    local blackPlaced = 0
    for _, pixel in pairs(blackPixels) do
        if not placementActive then break end
        if placeWithRetry(getWorldPos(pixel)) then blackPlaced += 1 end
    end
    print("Black Hole: " .. blackPlaced .. "/" .. #blackPixels)

    enableMovement()
    destroyPlatform()
    placementActive = false
    print("Done! " .. (whitePlaced + blackPlaced) .. "/" .. (#whitePixels + #blackPixels) .. " traps placed")
end

local function spawnControlGUI(playerGui)
    local controlGui = Instance.new("ScreenGui")
    controlGui.Name = "DrawControlGUI"
    controlGui.ResetOnSpawn = false
    controlGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    controlGui.Parent = playerGui
    drawGUI = controlGui

    local controlFrame = Instance.new("Frame")
    controlFrame.Size = UDim2.new(0, 290, 0, 100)
    controlFrame.Position = UDim2.new(0.5, -145, 1, -120)
    controlFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    controlFrame.BorderSizePixel = 0
    controlFrame.BackgroundTransparency = 1
    controlFrame.Parent = controlGui
    Instance.new("UICorner", controlFrame).CornerRadius = UDim.new(0, 12)

    local function makeBtn(text, bgColor, xPos, yPos, w, h)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, w, 0, h)
        btn.Position = UDim2.new(0, xPos, 0, yPos)
        btn.BackgroundColor3 = bgColor
        btn.BorderSizePixel = 0
        btn.Text = text
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 14
        btn.Font = Enum.Font.GothamBold
        btn.BackgroundTransparency = 1
        btn.TextTransparency = 1
        btn.Parent = controlFrame
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
        return btn
    end

    local rotateLeftBtn  = makeBtn("◄ Left",  Color3.fromRGB(60,  60,  180), 10,  15, 80, 40)
    local rotateRightBtn = makeBtn("Right ►", Color3.fromRGB(60,  60,  180), 100, 15, 80, 40)
    local placeBtn       = makeBtn("Place!",  Color3.fromRGB(50,  180, 50),  200, 15, 80, 40)
    local cancelBtn      = makeBtn("Cancel",  Color3.fromRGB(200, 50,  50),  10,  60, 270, 30)

    local ti = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    TweenService:Create(controlFrame, ti, {BackgroundTransparency = 0}):Play()
    for _, btn in pairs({rotateLeftBtn, rotateRightBtn, placeBtn, cancelBtn}) do
        TweenService:Create(btn, ti, {BackgroundTransparency = 0, TextTransparency = 0}):Play()
    end

    rotateLeftBtn.MouseButton1Click:Connect(function()
        currentRotation -= 90
        if previewOriginCFrame then
            movePreview(CFrame.new(previewOriginCFrame.Position) * CFrame.Angles(0, math.rad(currentRotation), 0))
        end
    end)

    rotateRightBtn.MouseButton1Click:Connect(function()
        currentRotation += 90
        if previewOriginCFrame then
            movePreview(CFrame.new(previewOriginCFrame.Position) * CFrame.Angles(0, math.rad(currentRotation), 0))
        end
    end)

    placeBtn.MouseButton1Click:Connect(function()
        destroyGUI()
        task.spawn(startPlacement)
    end)

    cancelBtn.MouseButton1Click:Connect(function()
        destroyGUI()
        destroyPreview()
        pixelData = nil
        placementActive = false
        currentRotation = 0
    end)
end

