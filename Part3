    -- Drag logic
    local dragging, dragStart, startPos = false, nil, nil
    local function updateDrag(input)
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
            input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
            input.UserInputType == Enum.UserInputType.Touch) then
            updateDrag(input)
        end
    end)

    closeButton.MouseButton1Click:Connect(function()
        destroyGUI()
        destroyPreview()
        pixelData = nil
        placementActive = false
    end)

    confirmButton.MouseButton1Click:Connect(function()
        local url = urlBox.Text
        if url == "" then return end

        confirmButton.Text = "Fetching..."
        confirmButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)

        task.spawn(function()
            local success, result = pcall(function()
                return request({
                    Url = API_URL .. url,
                    Method = "GET"
                })
            end)

            if not success or not result or result.StatusCode ~= 200 then
                confirmButton.Text = "Failed! Try again"
                confirmButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                task.wait(2)
                confirmButton.Text = "Confirm"
                confirmButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
                return
            end

            local data = HttpService:JSONDecode(result.Body)
            pixelData = data.pixels
            lastImageURL = url

            -- Save position before reset
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local savedPos = hrp and hrp.Position or Vector3.new(0, 5, 0)

            destroyGUI()
            print("Image fetched! Resetting character...")

            -- Reset character
            local resetOk = pcall(function()
                LocalPlayer:LoadCharacter()
            end)
            if not resetOk then
                ReplicatedStorage:WaitForChild("Remotes")
                    :WaitForChild("DeathEvent"):FireServer()
            end

            -- Wait for new character to load
            local newChar = LocalPlayer.CharacterAdded:Wait()
            task.wait(1.5)

            -- Teleport back to saved position
            local newHRP = newChar:WaitForChild("HumanoidRootPart")
            newHRP.CFrame = CFrame.new(savedPos.X, savedPos.Y + 3, savedPos.Z)
            task.wait(0.3)

            -- Show image preview on ground
            local previewCFrame = CFrame.new(savedPos.X, savedPos.Y, savedPos.Z)
                * CFrame.Angles(0, math.rad(currentRotation), 0)
            local p = createPreviewPart(url)
            p.CFrame = previewCFrame

            -- Spawn control GUI
            spawnControlGUI(playerGui)
            print("Image loaded! Drag to position, rotate, then hit Place!")
        end)
    end)
end

-- Touch drag for preview part
UserInputService.TouchMoved:Connect(function(touch, processed)
    if processed then return end
    if not previewPart then return end
    local unitRay = Camera:ScreenPointToRay(touch.Position.X, touch.Position.Y)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = { LocalPlayer.Character, previewPart }
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, raycastParams)
    if result then
        previewPart.CFrame = CFrame.new(result.Position.X, result.Position.Y + 0.05, result.Position.Z)
            * CFrame.Angles(0, math.rad(currentRotation), 0)
    end
end)

