    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
            input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
            input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    closeButton.MouseButton1Click:Connect(function()
        destroyGUI()
        destroyPreview()
        pixelData = nil
        placementActive = false
    end)

    confirmButton.MouseButton1Click:Connect(function()
        local url = urlBox.Text
        if url == "" then return end

        confirmButton.Text = "Fetching..."
        confirmButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)

        task.spawn(function()
            local success, result = pcall(function()
                return request({ Url = API_URL .. url, Method = "GET" })
            end)

            if not success or not result or result.StatusCode ~= 200 then
                confirmButton.Text = "Failed! Try again"
                confirmButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                task.wait(2)
                confirmButton.Text = "Confirm"
                confirmButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
                return
            end

            local data = HttpService:JSONDecode(result.Body)
            pixelData = data.pixels

            -- Save position
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local savedPos = hrp and hrp.Position or Vector3.new(0, 5, 0)

            destroyGUI()
            print("Resetting character...")

            -- Force reset via DeathEvent
            ReplicatedStorage:WaitForChild("Remotes")
                :WaitForChild("DeathEvent"):FireServer()

            -- Wait for new character
            local newChar = LocalPlayer.CharacterAdded:Wait()
            local newHRP = newChar:WaitForChild("HumanoidRootPart", 10)
            local newHum = newChar:WaitForChild("Humanoid", 10)
            repeat task.wait() until newHum.Health > 0 and newHRP.Position.Y > 0

            -- Teleport back
            newHRP.CFrame = CFrame.new(savedPos.X, savedPos.Y + 3, savedPos.Z)
            task.wait(0.1)

            -- Build cylinder preview
            local originCFrame = CFrame.new(savedPos.X, savedPos.Y + 0.1, savedPos.Z)
                * CFrame.Angles(0, math.rad(currentRotation), 0)
            buildPreview(pixelData, originCFrame)

            spawnControlGUI(playerGui)
            print("Ready! Drag to position, rotate, then hit Place!")
        end)
    end)
end

-- Touch drag moves whole preview
UserInputService.TouchMoved:Connect(function(touch, processed)
    if processed then return end
    if #previewParts == 0 then return end
    local unitRay = Camera:ScreenPointToRay(touch.Position.X, touch.Position.Y)
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = previewParts
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, rp)
    if result then
        movePreview(CFrame.new(result.Position.X, result.Position.Y + 0.1, result.Position.Z)
            * CFrame.Angles(0, math.rad(currentRotation), 0))
    end
end)

