local function equipTrap(trapName)
    local args = { "EquippingTrap", trapName }
    LocalPlayer:WaitForChild("PlayerGui")
        :WaitForChild("MainMenu"):WaitForChild("Shop")
        :WaitForChild("ShopMenu"):WaitForChild("TrapList")
        :WaitForChild("ShopRemote"):InvokeServer(unpack(args))
end

local function placeTrap()
    local args = { "PlaceTrap" }
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
        :WaitForChild("ChapterEvent"):FireServer(unpack(args))
end

local function freezeCharacter()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if hrp then
        hrp.Anchored = true
        hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, 0, math.rad(90))
    end
    if hum then
        hum.WalkSpeed = 0
        hum.JumpPower = 0
    end
end

local function unfreezeCharacter()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if hrp then
        hrp.Anchored = false
        hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, 0, 0)
    end
    if hum then
        hum.WalkSpeed = 16
        hum.JumpPower = 50
    end
end

local function destroyPreview()
    if previewPart then
        previewPart:Destroy()
        previewPart = nil
    end
end

local function destroyGUI()
    if drawGUI then
        drawGUI:Destroy()
        drawGUI = nil
    end
end

local function createPreviewPart()
    if previewPart then previewPart:Destroy() end
    local part = Instance.new("Part")
    part.Size = Vector3.new(CANVAS_SIZE, 0.1, CANVAS_SIZE)
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 0.5
    part.BrickColor = BrickColor.new("Bright blue")
    part.Material = Enum.Material.Neon
    part.Parent = workspace
    previewPart = part

    local texture = Instance.new("Texture")
    texture.Texture = "rbxassetid://6372755229"
    texture.StudsPerTileU = GRID_SIZE
    texture.StudsPerTileV = GRID_SIZE
    texture.Transparency = 0.5
    texture.Face = Enum.NormalId.Top
    texture.Parent = part

    return part
end

local function startPlacement()
    if not pixelData or not previewPart then return end

    local origin = previewPart.CFrame
    destroyPreview()
    placementActive = true

    local whitePixels = {}
    local blackPixels = {}
    for _, pixel in pairs(pixelData) do
        if pixel.color == "white" then
            table.insert(whitePixels, pixel)
        else
            table.insert(blackPixels, pixel)
        end
    end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local function getWorldPos(pixel)
        local offsetX = (pixel.x - 32) * GRID_SIZE
        local offsetZ = (pixel.y - 32) * GRID_SIZE
        local localOffset = Vector3.new(offsetX, 0, offsetZ)
        local worldOffset = origin:VectorToWorldSpace(localOffset)
        return origin.Position + worldOffset
    end

    freezeCharacter()

    equipTrap("Default")
    task.wait(0.2)
    for _, pixel in pairs(whitePixels) do
        if not placementActive then break end
        local pos = getWorldPos(pixel)
        hrp.CFrame = CFrame.new(pos.X, hrp.Position.Y, pos.Z) * CFrame.Angles(0, 0, math.rad(90))
        task.wait()
        placeTrap()
        task.wait()
    end

    equipTrap("Black Hole")
    task.wait(0.2)
    for _, pixel in pairs(blackPixels) do
        if not placementActive then break end
        local pos = getWorldPos(pixel)
        hrp.CFrame = CFrame.new(pos.X, hrp.Position.Y, pos.Z) * CFrame.Angles(0, 0, math.rad(90))
        task.wait()
        placeTrap()
        task.wait()
    end

    unfreezeCharacter()
    placementActive = false
    print("Draw complete!")
end

local function addFadeIn(gui, elements)
    for _, element in pairs(elements) do
        if element:IsA("Frame") or element:IsA("TextButton") or element:IsA("TextLabel") or element:IsA("TextBox") then
            if element:IsA("TextLabel") or element:IsA("TextButton") or element:IsA("TextBox") then
                element.TextTransparency = 1
                TweenService:Create(element, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
            end
            element.BackgroundTransparency = 1
            TweenService:Create(element, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = element:IsA("Frame") and (element.Name == "MainFrame" and 0 or 0) or 0}):Play()
        end
    end
end

